{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/make-my-resume-fit/metadata.schema.json",
  "title": "MakeMyResumeFit Resume Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "slug",
    "summary",
    "target_files",
    "warnings",
    "changes"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "slug": {
      "type": "string",
      "description": "Summarized slug in the form <shortened company name>-<shortened position>.",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "summary": {
      "type": "string"
    },
    "target_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "section",
          "location_hint",
          "change_type",
          "before",
          "after",
          "reason",
          "evidence",
          "truthfulness_risk"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "section": {
            "type": "string"
          },
          "location_hint": {
            "type": "string"
          },
          "change_type": {
            "type": "string"
          },
          "before": {
            "type": "string"
          },
          "after": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "truthfulness_risk": {
            "type": "string"
          }
        }
      }
    }
  }
}
